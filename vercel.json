{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/api/v4/sessions/([^/]+)/assessment-preview",
      "dest": "/api/v4/sessions/assessment-preview?sessionId=$1"
    },
    {
      "src": "/api/v4/sessions/([^/]+)/builder-plan",
      "dest": "/api/v4/sessions/builder-plan?sessionId=$1"
    },
    {
      "src": "/api/v4/sessions/([^/]+)/blueprint",
      "dest": "/api/v4/sessions/blueprint?sessionId=$1"
    },
    {
      "src": "/api/v4/documents/([^/]+)/visibility",
      "dest": "/api/v4/documents/[documentId]/visibility?documentId=$1"
    },
    {
      "src": "/api/v4/simulations/([^/]+)",
      "dest": "/api/v4/simulations/[simulationId]?simulationId=$1"
    },
    {
      "src": "/api/v4/classes/([^/]+)/regenerate",
      "dest": "/api/v4/classes/[classId]/regenerate?classId=$1"
    },
    {
      "src": "/api/v4/classes/([^/]+)/performance",
      "dest": "/api/v4/classes/[classId]/performance?classId=$1"
    },
    {
      "src": "/api/v4/classes/([^/]+)/differentiated-build",
      "dest": "/api/v4/classes/[classId]/differentiated-build?classId=$1"
    },
    {
      "src": "/api/v4/classes/([^/]+)/results/actual",
      "dest": "/api/v4/classes/[classId]/results/actual?classId=$1"
    },
    {
      "src": "/api/v4/classes/([^/]+)/results/compare",
      "dest": "/api/v4/classes/[classId]/results/compare?classId=$1"
    },
    {
      "src": "/api/v4/classes/([^/]+)/results",
      "dest": "/api/v4/classes/[classId]/results?classId=$1"
    },
    {
      "src": "/api/v4/classes/([^/]+)",
      "dest": "/api/v4/classes/[classId]?classId=$1"
    },
    {
      "src": "/.*",
      "dest": "/index.html"
    }
  ]
}

{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "server/rewrite.ts": {
      "runtime": "nodejs18.x"
    },
    "server/llm.ts": {
      "runtime": "nodejs18.x"
    },
    "server/generate-assessment.ts": {
      "runtime": "nodejs18.x"
    }
  },
  "rewrites": [
    {
      "source": "/api/rewrite",
      "destination": "/server/rewrite"
    },
    {
      "source": "/api/llm",
      "destination": "/server/llm"
    },
    {
      "source": "/api/generate-assessment",
      "destination": "/server/generate-assessment.ts"
    }
  ]
}

# =====================================================
# AZURE DOCUMENT INTELLIGENCE
# =====================================================

AZURE_DOCUMENT_ENDPOINT=your_azure_document_endpoint_here
AZURE_DOCUMENT_KEY=your_azure_document_key_here

# =====================================================
# LLM STUB MODE
# =====================================================

# Backend / server runtime (stub identifier only)
STUB_LLM_KEY=stub-llm-key

# Frontend Vite env (optional)
VITE_STUB_LLM_KEY=stub-llm-key

# =====================================================
# SUPABASE
# =====================================================

VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_URL=your_supabase_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# =====================================================
# FRONTEND FLAGS / DEBUG
# =====================================================

VITE_USE_AZURE=true
INGESTION_DEBUG_AZURE=false
